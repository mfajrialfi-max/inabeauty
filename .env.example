NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional but recommended: comma-separated admin email allowlist.
# Admin users must still have app_metadata.role = "admin" in Supabase Auth.
ADMIN_EMAILS=admin@example.com

# Optional fallback used before site_settings is saved in Supabase.
NEXT_PUBLIC_DEFAULT_WHATSAPP_NUMBER=6281234567890
